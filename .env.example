# WCDAILY — Environment Variables
# Copy this to .env and fill in your values
# Then run: export $(cat .env | xargs) && python bot.py

# ── REQUIRED ──────────────────────────────────────────
# Get from @BotFather on Telegram
TELEGRAM_TOKEN=your_bot_token_here

# Your personal Telegram user ID (get from @userinfobot)
TELEGRAM_ADMIN_ID=your_telegram_user_id

# ── MATCH DATA (free) ─────────────────────────────────
# Register free at https://www.football-data.org/
FOOTBALL_API_KEY=your_football_data_key

# ── AI CAPTIONS (optional) ────────────────────────────
# https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key

# ── INSTAGRAM (free, needs Business account) ──────────
# https://developers.facebook.com/
IG_ACCESS_TOKEN=your_ig_access_token
IG_USER_ID=your_ig_user_id

# ── TIKTOK (free) ─────────────────────────────────────
# https://developers.tiktok.com/
TIKTOK_ACCESS_TOKEN=your_tiktok_token

# ── APIFY (free $5/month) ─────────────────────────────
# https://apify.com/ — only needed for cloud video cutting
APIFY_TOKEN=your_apify_token
